# ADS-B data source (on the Pi, this is localhost)
ADSB_URL=http://localhost/tar1090/data/aircraft.json

# Polling interval in seconds (default: 5)
POLL_INTERVAL=5

# Seconds of silence before an aircraft session is considered ended (default: 300)
SESSION_TIMEOUT=300

# PostgreSQL connection (pointing at the NAS)
DATABASE_URL=postgresql://flighttracker:changeme@<nas-ip>:5431/flighttracker

# Only needed when running the DB via docker-compose (e.g. local dev)
# DB_PASSWORD=changeme
